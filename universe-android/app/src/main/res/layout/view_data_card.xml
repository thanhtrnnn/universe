<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/card_background"
    android:elevation="2dp"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/cardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/slate_900"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/cardSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:textColor="@color/slate_600"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/cardMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:textColor="@color/cyan_700"
        android:textSize="13sp" />

    <Button
        android:id="@+id/cardAction"
        style="@style/Widget.UniVerse.Button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="12dp"
        android:text="@string/register"
        android:visibility="gone" />
</LinearLayout>
