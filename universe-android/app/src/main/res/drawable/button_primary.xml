<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="@color/slate_400" />
            <corners android:radius="14dp" />
            <padding
                android:bottom="10dp"
                android:left="16dp"
                android:right="16dp"
                android:top="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="@color/blue_500"
                android:startColor="@color/cyan_400" />
            <corners android:radius="14dp" />
            <padding
                android:bottom="10dp"
                android:left="16dp"
                android:right="16dp"
                android:top="10dp" />
        </shape>
    </item>
</selector>
